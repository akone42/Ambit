PORT=3001
CLIENT_URL=http://localhost:5173

# Neon PostgreSQL connection string
# Get it from: neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT signing secret — any long random string, keep it secret
JWT_SECRET=replace_this_with_a_long_random_string

# Cloudinary credentials
# Get them from: cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe credentials
# Get them from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Email (nodemailer)
# Gmail: enable 2-Step Verification → Security → App Passwords → generate one
# Mailtrap (for testing): use sandbox.smtp.mailtrap.io credentials
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Ambit Marketplace <you@gmail.com>
